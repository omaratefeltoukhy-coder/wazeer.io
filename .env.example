# Wazeer AI — example env file. Copy to .env and fill in real values.
# Never commit .env, .env.development, or .env.production.

# --- Supabase (required) ---
# Find these in Lovable Cloud → Supabase, or in Supabase project settings → API.
# The "publishable key" is the anon key (safe to expose to the browser; RLS-guarded).
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# --- Paddle (required for billing) ---
# Use the test token in dev (.env.development), live in prod (.env.production).
VITE_PAYMENTS_CLIENT_TOKEN=""
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""

# --- Email (Resend) ---
RESEND_API_KEY=""

# --- Newsletter (Beehiiv) ---
BEEHIIV_API_KEY=""
BEEHIIV_PUBLICATION_ID=""

# --- Meta (Facebook / Instagram / Ads) ---
# Server-only. Never expose to the client bundle.
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI=""
# 32-byte key used to encrypt Meta access tokens at rest in meta_connections.
META_TOKEN_ENCRYPTION_KEY=""

# --- AI providers (server-only) ---
LOVABLE_AI_API_KEY=""
# Optional fallbacks for image / video generation — fill in if used.
OPENAI_API_KEY=""
REPLICATE_API_TOKEN=""
