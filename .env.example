# ============================================
# Wazeer — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# ── Supabase ──
# Get these from your Supabase project Settings > API
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Vite requires VITE_ prefix for client-side env vars
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# ── AI Generation ──
# Lovable Cloud is blocked in some regions (e.g. UAE).
# Use OpenAI as primary — Lovable as optional fallback.
# Get OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional fallback (if Lovable is available in your region):
# Get from: https://cloud.lovable.dev/ > API Keys
LOVABLE_API_KEY=lovable_...

# ── Email (Resend) ──
# Required for: real email campaigns, automation delivery, delivery tracking
# Sign up: https://resend.com/signup
# Get API key: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
MARKETING_FROM_EMAIL="Your Name <you@wazeer.io>"
# Add your domain to Resend and verify it: https://resend.com/domains

# ── Payments (Stripe — Recommended for UAE) ──
# Required for: plan upgrades, credit top-ups, payment link checkout
# Stripe works in UAE with no complex verification. Sign up:
# https://dashboard.stripe.com/register
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Payments (Paddle — Optional backup) ──
# Harder to set up in UAE. Only use if Stripe is unavailable.
# Sign up: https://sandbox-vendors.paddle.com/signup (sandbox first)
VITE_PAYMENTS_CLIENT_TOKEN=test_... or live_...
PADDLE_SANDBOX_API_KEY=...
PADDLE_LIVE_API_KEY=...
PAYMENTS_SANDBOX_WEBHOOK_SECRET=pdl_ntfset_...
PAYMENTS_LIVE_WEBHOOK_SECRET=pdl_ntfset_...

# ── Meta (Facebook/Instagram) ──
# Required for: publishing posts to Facebook Pages, Instagram Business accounts
# Create app: https://developers.facebook.com/apps/
# Get tokens from your app's Dashboard > Settings > Basic
META_APP_ID=...
META_APP_SECRET=...
META_REDIRECT_URI=https://wazeer.io/dashboard/integrations/meta
META_TOKEN_ENCRYPTION_KEY=your-random-32-char-key-here!!!

# ── Image Generation (Optional — overrides mock mode) ──
# Set to: openai | fal | stability | mock
# If mock, images use picsum.photos placeholders
IMAGE_PROVIDER=mock
FAL_API_KEY=...
STABILITY_API_KEY=sk-...

# ── Video Generation (Optional — overrides mock mode) ──
# Set to: runway | fal | pika | lovable | mock
# If mock, videos use sample MP4s
VIDEO_PROVIDER=mock
RUNWAY_API_KEY=...
FAL_VIDEO_API_KEY=...
PIKA_API_KEY=...

# ── Site / App ──
SITE_URL=https://wazeer.io
# Used for unsubscribe links, webhook callbacks, redirects

# ── Internal ──
# Set this to "live" when you're ready to process real payments
BILLING_PROVIDER=mock
# Options: mock | stripe | paddle
